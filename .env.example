# App Settings
APP_PORT=:8080
APP_ENV=development

# Database Settings
DB_HOST=localhost
DB_PORT=5432
DB_USER=qlass_root
DB_NAME=qlass_db
DB_SSLMODE=disable

# Database Password (Used by Docker & Go App)
DB_PASSWORD=password

# PgAdmin Login (For accessing http://localhost:5050)
PGADMIN_EMAIL=admin@qlass.com
PGADMIN_PASSWORD=password

# JWT Secret (For signing tokens)
JWT_SECRET=secret

# Redis Configuration
REDIS_HOST=localhost
REDIS_USERNAME=qlass_root
REDIS_PORT=6379
REDIS_PASSWORD=password
REDIS_DB=0